@model IEnumerable<DbFirstDemo.Models.Employees>

@{
    ViewData["Title"] = "Employee Profiles";
}

<div class="container py-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Employee Profiles</h2>

        <button id="darkToggle" class="btn btn-outline-secondary">
            🌙 Toggle Dark Mode
        </button>
    </div>

    <!-- Search + Sort Card -->
    <div class="card border-1 shadow-sm rounded-4 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">

                <div class="col-md-6">
                    <input type="text"
                           name="search"
                           value="@ViewBag.CurrentSearch"
                           class="form-control"
                           placeholder="Search employee by name..." />
                </div>

                <div class="col-md-4">
                    <select name="sortOrder" class="form-select">
                        <option value="">Sort by ID (Default)</option>
                        <option value="salary_asc" selected="@(ViewBag.CurrentSort == "salary_asc")">
                            Salary Low → High
                        </option>
                        <option value="salary_desc" selected="@(ViewBag.CurrentSort == "salary_desc")">
                            Salary High → Low
                        </option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">
                        Apply
                    </button>
                </div>

            </form>
        </div>
    </div>

    <!-- YOUR ACCORDION (UNCHANGED STRUCTURE) -->
    <div class="accordion" id="employeeAccordion">

        @foreach (var emp in Model)
        {
            <div class="accordion-item border-1 shadow-sm mb-3 rounded-4 overflow-hidden">

                <h2 class="accordion-header" id="heading-@emp.EmployeeID">
                    <button class="accordion-button collapsed fw-semibold"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapse-@emp.EmployeeID"
                            aria-expanded="false">

                        <div class="d-flex justify-content-between w-100 me-3">
                            <span>
                                @emp.FirstName @emp.LastName
                            </span>

                            <span class="badge bg-primary-subtle text-primary rounded-pill px-3">
                                $ @emp.Salary
                            </span>
                        </div>
                    </button>
                </h2>

                <div id="collapse-@emp.EmployeeID"
                     class="accordion-collapse collapse"
                     data-bs-parent="#employeeAccordion">

                    <div class="accordion-body bg-light">

                        <div class="row g-4">

                            <div class="col-md-4">
                                <div class="card border-0 shadow-sm rounded-4 p-3">
                                    <h6 class="text-muted">Basic Info</h6>
                                    <p><strong>ID:</strong> @emp.EmployeeID</p>
                                    <p><strong>Hire Date:</strong> @emp.HireDate</p>
                                    <p><strong>Department:</strong> @(emp.Department?.DepartmentName ?? "N/A")</p>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <div class="card border-0 shadow-sm rounded-4 p-3">
                                    <h6 class="text-muted mb-3">Projects</h6>

                                    @if (emp.EmployeeProjects.Any())
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Project</th>
                                                        <th>Role</th>
                                                        <th>Hours</th>
                                                        <th>Budget</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var ep in emp.EmployeeProjects)
                                                    {
                                                        <tr>
                                                            <td>@ep.Project?.ProjectName</td>
                                                            <td>@ep.Role</td>
                                                            <td>@ep.HoursWorked</td>
                                                            <td>₹ @ep.Project?.Budget</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                    else
                                    {
                                        <p class="text-muted">No projects assigned.</p>
                                    }

                                </div>
                            </div>

                        </div>

                    </div>
                </div>

            </div>
        }

    </div>

</div>

<script>
    const toggleBtn = document.getElementById("darkToggle");

    toggleBtn.addEventListener("click", function () {
        document.body.classList.toggle("bg-dark");
        document.body.classList.toggle("text-light");

        document.querySelectorAll(".card").forEach(card => {
            card.classList.toggle("bg-dark");
            card.classList.toggle("text-light");
        });

        document.querySelectorAll(".accordion-button").forEach(btn => {
            btn.classList.toggle("bg-dark");
            btn.classList.toggle("text-light");
        });

        document.querySelectorAll(".table").forEach(table => {
            table.classList.toggle("table-dark");
        });
    });
</script>