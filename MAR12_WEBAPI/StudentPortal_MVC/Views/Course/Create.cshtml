@model StudentPortal_MVC.Models.Course

<div class="card p-4">

    <div class="d-flex justify-content-between mb-3">

        <h3>Courses</h3>

        <a href="/Course/Create" class="btn btn-primary">
            + Add Course
        </a>

    </div>

    <form method="post">

        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Duration (Days)</label>
            <input asp-for="DurationDays" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Fee</label>
            <input asp-for="Fee" class="form-control" />
        </div>

        <div class="mb-3">
            <label>Level</label>
            <input asp-for="Level" class="form-control" />
        </div>

        <button class="btn btn-success">Save</button>

    </form>

</div>