<!DOCTYPE html>
<html>
<head>
    <title>Student Portal</title>

    <link rel="stylesheet"          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
            body {
                background: #f4f6f9;
            }

            .navbar {
                background: #111827;
            }

            .navbar-brand {
                color: white;
                font-weight: 600;
            }

            .card {
                border-radius: 12px;
                box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
            }
    </style>

</head>


<body>

    <nav class="navbar navbar-dark px-4">
        <span class="navbar-brand">🎓 Student Portal</span>
        <a class="nav-link text-light" href="/Course">Courses</a>
        <a class="nav-link text-light" href="/Student">Students</a>
        <a class="nav-link text-light" href="/Enrollment">Enrollments</a>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

</body>

</html>