@model List<Shared.Models.CartItem>
@{
    ViewData["Title"] = "Your Cart";
    decimal total = ViewBag.Total ?? 0m;
}

<div class="container py-5">
    <h1 class="fw-bold mb-4" style="color: #4f46e5;"><i class="bi bi-cart3 me-2"></i>Your Cart</h1>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x" style="font-size: 5rem; color: #d1d5db;"></i>
            <h3 class="mt-3 text-muted">Your cart is empty</h3>
            <p class="text-muted">Head back to the products page and add some items!</p>
            <a href="/" class="btn btn-primary mt-2 px-4">
                <i class="bi bi-arrow-left me-1"></i>Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0" style="border-radius: 16px; overflow: hidden;">
                            <thead style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white;">
                                <tr>
                                    <th class="py-3 ps-4">Product</th>
                                    <th class="py-3 text-center">Qty</th>
                                    <th class="py-3 text-end">Unit Price</th>
                                    <th class="py-3 pe-4 text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-3 fw-semibold align-middle">
                                            <i class="bi bi-box-seam me-2" style="color: #6366f1;"></i>@item.ProductName
                                        </td>
                                        <td class="py-3 text-center align-middle">
                                            <span class="badge rounded-pill px-3 py-2" style="background: #e0e7ff; color: #4f46e5; font-size: 0.95rem;">@item.Quantity</span>
                                        </td>
                                        <td class="py-3 text-end align-middle text-muted">₹@item.Price.ToString("N0")</td>
                                        <td class="pe-4 py-3 text-end align-middle fw-bold" style="color: #4f46e5;">₹@((item.Price * item.Quantity).ToString("N0"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="mt-3">
                    <a href="/" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Continue Shopping
                    </a>
                </div>
            </div>

            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="card border-0 shadow-sm" style="border-radius: 16px;">
                    <div class="card-header border-0 fw-bold py-3 px-4" style="background: #f3f4f6; border-radius: 16px 16px 0 0; font-size: 1.05rem;">
                        <i class="bi bi-receipt me-2" style="color: #6366f1;"></i>Order Summary
                    </div>
                    <div class="card-body px-4">
                        <div class="d-flex justify-content-between text-muted mb-2">
                            <span>Items (@Model.Sum(i => i.Quantity))</span>
                            <span>₹@total.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted mb-2">
                            <span>Shipping</span>
                            <span class="text-success fw-semibold">FREE</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5 mb-4">
                            <span>Total</span>
                            <span style="color: #4f46e5;">₹@total.ToString("N0")</span>
                        </div>
                        <form asp-controller="Cart" asp-action="Pay" method="post">
                            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold" style="border-radius: 10px; font-size: 1.05rem;">
                                <i class="bi bi-credit-card me-2"></i>Proceed to Pay
                            </button>
                        </form>
                        <p class="text-muted text-center small mt-3 mb-0">
                            <i class="bi bi-shield-lock me-1"></i>Secured by RabbitMQ payment_queue
                        </p>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
