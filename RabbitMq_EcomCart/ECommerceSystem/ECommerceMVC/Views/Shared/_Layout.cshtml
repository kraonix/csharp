<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ShopZone</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #8b5cf6;
        }
        body { background: #f8f9fc; font-family: 'Segoe UI', sans-serif; }
        .navbar { background: linear-gradient(135deg, var(--primary), var(--secondary)) !important; box-shadow: 0 2px 15px rgba(99,102,241,0.3); }
        .navbar-brand { font-weight: 700; font-size: 1.4rem; letter-spacing: 0.5px; }
        .nav-link { font-weight: 500; }
        .cart-badge { background: #f59e0b; color: #fff; border-radius: 50%; padding: 2px 7px; font-size: 0.72rem; font-weight: 700; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
        footer { background: #1e1b4b; color: #a5b4fc; padding: 1.5rem 0; margin-top: 4rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand text-white" href="/">
                <i class="bi bi-bag-heart-fill me-2"></i>ShopZone
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/"><i class="bi bi-grid me-1"></i>Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/Cart">
                            <i class="bi bi-cart3 me-1"></i>Cart
                            @if (ViewBag.CartCount != null && ViewBag.CartCount > 0)
                            {
                                <span class="cart-badge">@ViewBag.CartCount</span>
                            }
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="text-center">
        <p class="mb-0"><i class="bi bi-bag-heart me-1"></i> ShopZone &mdash; Mini E-Commerce &middot; Powered by ASP.NET Core + RabbitMQ</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
