@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            height: 100vh;
            background: #EAEFEF;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI';
        }

        .login-container {
            display: flex;
            width: 850px;
            border-radius: 20px;
            overflow: hidden;
            background: white;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        }

        /* LEFT PANEL */
        .left-panel {
            width: 50%;
            background: #25343F;
            color: #EAEFEF;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand {
            font-size: 30px;
            font-weight: bold;
        }

        .subtitle {
            margin-top: 15px;
            opacity: 0.8;
            line-height: 1.6;
        }

        .tag {
            margin-top: 20px;
            font-size: 13px;
            opacity: 0.7;
        }

        /* RIGHT PANEL */
        .right-panel {
            width: 50%;
            padding: 50px;
            background: #ffffff;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #BFC9D1;
            padding: 12px;
        }

        .form-control:focus {
            border-color: #FF9B51;
            box-shadow: none;
        }

        .btn-main {
            background: #FF9B51;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            transition: 0.3s;
        }

        .btn-main:hover {
            background: #e88842;
        }

        .btn-outline-custom {
            border: 1px solid #BFC9D1;
            border-radius: 10px;
            padding: 12px;
            color: #25343F;
            transition: 0.3s;
        }

        .btn-outline-custom:hover {
            background: #EAEFEF;
        }

        h4 {
            color: #25343F;
            font-weight: 600;
        }

        .note {
            font-size: 13px;
            color: #7a8a93;
        }
    </style>
</head>

<body>

<div class="login-container">

    <!-- LEFT SIDE -->
    <div class="left-panel">
        <div class="brand">🎓 UniManage</div>

        <p class="subtitle">
            A modern platform to manage students, faculty, courses, and everything — all in one place.
        </p>

        <div class="tag">
            Secure • Role-Based • Scalable System
        </div>
    </div>

    <!-- RIGHT SIDE -->
    <div class="right-panel">

        <h4 class="mb-4 text-center">Welcome Back 👋</h4>

        <form method="post" asp-action="Login">

            <div class="mb-3">
                <input type="text" name="Username" class="form-control" placeholder="Email / Username" required />
            </div>

            <div class="mb-3">
                <input type="password" name="Password" class="form-control" placeholder="Password" required />
            </div>

            <button type="submit" class="btn btn-main w-100 mb-3">
                Login
            </button>

            <a href="/auth/register" class="btn btn-outline-custom w-100">
                Create Account Request
            </a>

        </form>

        <p class="text-center mt-3 note">
            First-time password: <b>First@123</b>
        </p>

    </div>

</div>

</body>
</html>