@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Change Password</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            height: 100vh;
            background: #EAEFEF;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI';
        }

        .container-box {
            width: 800px;
            display: flex;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
        }

        /* LEFT PANEL */
        .left-panel {
            width: 50%;
            background: #25343F;
            color: #EAEFEF;
            padding: 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .left-panel h2 {
            font-weight: bold;
        }

        .left-panel p {
            opacity: 0.8;
            margin-top: 10px;
        }

        /* RIGHT PANEL */
        .right-panel {
            width: 50%;
            background: white;
            padding: 50px;
        }

        .form-control {
            border-radius: 10px;
            border: 1px solid #BFC9D1;
            padding: 12px;
        }

        .form-control:focus {
            border-color: #FF9B51;
            box-shadow: none;
        }

        .btn-main {
            background: #FF9B51;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 12px;
            transition: 0.3s;
        }

        .btn-main:hover {
            background: #e88842;
        }

        .note {
            font-size: 13px;
            color: #7a8a93;
        }
    </style>
</head>

<body>

<div class="container-box">

    <!-- LEFT -->
    <div class="left-panel">
        <h2>🔐 Security First</h2>
        <p>
            For your safety, please update your password before accessing the system.
        </p>

        <small class="mt-3">
            First-time login requires password change.
        </small>
    </div>

    <!-- RIGHT -->
    <div class="right-panel">

        <h4 class="text-center mb-4">Change Password</h4>

        <form method="post">

            <div class="mb-3">
                <input type="password" name="newPassword"
                       class="form-control"
                       placeholder="Enter New Password"
                       required />
            </div>

            <button class="btn btn-main w-100">
                Update Password
            </button>

        </form>

        <p class="text-center mt-3 note">
            Make sure your password is strong 🔒
        </p>

    </div>

</div>

</body>
</html>