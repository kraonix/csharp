@model List<Enrollment>

<h2>My Grades</h2>

<table class="table">
    <tr>
        <th>Course</th>
        <th>Grade</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Course.Name</td>
            <td>@(item.Grade ?? "Pending")</td>
        </tr>
    }
</table>