@model LibraryApp.Models.Book

<div class="container mt-5">

    <div class="card shadow col-md-6 mx-auto">
        <div class="card-body">

            <h3 class="mb-4 text-center">Book Details</h3>

            <div class="mb-3">
                <strong>ID:</strong> @Model.BookId
            </div>

            <div class="mb-3">
                <strong>Title:</strong> @Model.Title
            </div>

            <div class="mb-3">
                <strong>Author:</strong> @Model.Author
            </div>

            <div class="mb-3">
                <strong>Price:</strong> ₹@Model.Price
            </div>

            <div class="text-center mt-4">
                <a asp-action="List" class="btn btn-primary">
                    Back to List
                </a>
            </div>

        </div>
    </div>

</div>