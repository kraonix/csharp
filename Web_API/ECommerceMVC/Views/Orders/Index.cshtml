@model List<Order>

<h2 class="mb-4">Orders</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No orders found.</div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>User ID</th>
                <th>Total Amount</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td>@order.Id</td>
                    <td>@order.UserId</td>
                    <td>₹@order.TotalAmount</td>
                    <td>
                        <span class="badge @(order.Status == "Placed" ? "bg-primary" : order.Status == "Shipped" ? "bg-success" : "bg-secondary")">
                            @order.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
